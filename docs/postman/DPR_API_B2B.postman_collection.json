{
  "info": {
    "name": "DPR API B2B",
    "description": "Coleccion Postman para probar la API B2B de DPR Pension Segura.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "x-api-key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{API_KEY}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://us-central1-pensionsegura-9c817.cloudfunctions.net/api"
    },
    {
      "key": "SOLICITUD_ID",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/health",
          "host": ["{{BASE_URL}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Balance",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/balance",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "balance"]
        }
      }
    },
    {
      "name": "Services",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/services",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "services"]
        }
      }
    },
    {
      "name": "Create Request JSON",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const json = pm.response.json();",
              "  if (json.solicitud_id) {",
              "    pm.environment.set('SOLICITUD_ID', json.solicitud_id);",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"service_code\": \"CURP\",\n  \"external_reference\": \"POSTMAN-JSON-001\",\n  \"curp\": \"XXXX000000XXXXXX00\",\n  \"nss\": \"N/A\",\n  \"details\": {\n    \"nombre_cliente\": \"Cliente Prueba Postman\",\n    \"telefono\": \"8440000000\",\n    \"correo\": \"prueba@correo.com\",\n    \"nota\": \"Solicitud JSON desde Postman\"\n  },\n  \"cuestionario\": {\n    \"origen\": \"postman\",\n    \"tipo_prueba\": \"json\"\n  }\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/requests",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "requests"]
        }
      }
    },
    {
      "name": "Create Request With Files",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const json = pm.response.json();",
              "  if (json.solicitud_id) {",
              "    pm.environment.set('SOLICITUD_ID', json.solicitud_id);",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "service_code",
              "value": "CURP",
              "type": "text"
            },
            {
              "key": "external_reference",
              "value": "POSTMAN-FILE-001",
              "type": "text"
            },
            {
              "key": "curp",
              "value": "XXXX000000XXXXXX00",
              "type": "text"
            },
            {
              "key": "nss",
              "value": "N/A",
              "type": "text"
            },
            {
              "key": "details",
              "value": "{\"nombre_cliente\":\"Cliente Prueba Postman\",\"telefono\":\"8440000000\",\"correo\":\"prueba@correo.com\",\"nota\":\"Solicitud multipart desde Postman\"}",
              "type": "text"
            },
            {
              "key": "cuestionario",
              "value": "{\"origen\":\"postman\",\"tipo_prueba\":\"multipart\"}",
              "type": "text"
            },
            {
              "key": "file_ine_f",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/requests-with-files",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "requests-with-files"]
        }
      }
    },
    {
      "name": "Get Request Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/requests/{{SOLICITUD_ID}}",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "requests", "{{SOLICITUD_ID}}"]
        }
      }
    },
    {
      "name": "Get Request Result",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/requests/{{SOLICITUD_ID}}/result",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "requests", "{{SOLICITUD_ID}}", "result"]
        }
      }
    }
  ]
}
